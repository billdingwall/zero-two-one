{
  "name": "zero-two-one",
  "version": "1.1.0",
  "description": "Zero Two One — an agentic product framework that takes new products from point 0 (idea) to point 1 (MVP) via project-level refinement loops and Spec Kit-driven feature delivery.",
  "main": "index.js",
  "bin": {
    "zero-two-one-init": "bin/init.js"
  },
  "scripts": {
    "021-status": "node scripts/workflow-status.js",
    "021-qa": "sh scripts/run-qa.sh",
    "021-spec:status": "node scripts/speckit/spec-status.js",
    "021-spec:context": "node scripts/speckit/fetch-speckit-context.js",
    "021-spec:verify": "node scripts/speckit/verify-spec-compliance.js",
    "test": "node scripts/speckit/spec-status.js list && node scripts/workflow-status.js",
    "sync:package": "node scripts/sync-to-package.js",
    "publish:package": "npm run sync:package && cd package && npm publish"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/billdingwall/zero-two-one.git"
  },
  "keywords": [
    "spec-driven-development",
    "speckit",
    "ai-agents",
    "product-framework",
    "lifecycle"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/billdingwall/zero-two-one/issues"
  },
  "homepage": "https://github.com/billdingwall/zero-two-one#readme"
}
